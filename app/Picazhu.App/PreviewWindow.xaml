<Window x:Class="Picazhu.App.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Preview"
        Icon="pack://application:,,,/Assets/picazhulogo.png"
        Width="1040"
        Height="760"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}">
    <Border Margin="12" Padding="16" CornerRadius="24" Background="{StaticResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelGlassBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="0,0,12,0">
                        <Image Source="pack://application:,,,/Assets/picazhulogo.png" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Quick Preview" Style="{StaticResource SectionTitleStyle}" FontSize="22" />
                        <TextBlock Text="Focused viewing without leaving the browser." Style="{StaticResource SectionCaptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelGlassBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="14"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Border Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="10">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <MediaElement x:Name="PreviewVideo"
                                          Stretch="Uniform"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          ScrubbingEnabled="True"
                                          Visibility="Collapsed"
                                          MediaOpened="PreviewVideo_MediaOpened"
                                          MediaFailed="PreviewVideo_MediaFailed" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
