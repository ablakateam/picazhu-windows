<Window x:Class="Picazhu.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PICAZHU Settings"
        Width="860"
        Height="720"
        MinWidth="620"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}">
    <Border Margin="18" Background="{StaticResource WindowBackgroundBrush}" CornerRadius="24">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="General behavior, cache control, and AI provider configuration live here now, not under the preview rail." Style="{StaticResource SectionCaptionStyle}" Margin="0,6,0,0" />
                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="10,6" Margin="0,12,0,0" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding SettingsStatusText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Click="Close_Click" Style="{StaticResource GhostButtonStyle}" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE711;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                        <TextBlock Text="Close" />
                    </StackPanel>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,18">
                <StackPanel>
                    <WrapPanel ItemWidth="390" Margin="0,0,0,4">
                        <Border Width="390" Background="{StaticResource PanelGlassBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="20" Padding="18" Margin="0,0,16,16">
                            <StackPanel>
                                <TextBlock Text="Workspace" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Control how PICAZHU feels during day-to-day browsing." FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="These settings affect shell density, default browsing behavior, and thumbnail cache size." Style="{StaticResource SectionCaptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />

                                <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <ComboBox SelectedValue="{Binding ThemeMode}" SelectedValuePath="Tag" Margin="0,8,0,0">
                                    <ComboBoxItem Content="Dark" Tag="Dark" />
                                    <ComboBoxItem Content="Light" Tag="Light" />
                                </ComboBox>

                                <CheckBox Content="Show subfolders by default" Style="{StaticResource FilterCheckBoxStyle}" IsChecked="{Binding IncludeSubfolders}" Margin="0,18,0,0" />

                                <TextBlock Text="Thumbnail cache limit (MB)" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <TextBox Text="{Binding ThumbnailCacheLimitMb}" Margin="0,8,0,0" />

                                <Border Background="{StaticResource PanelAltBrush}" CornerRadius="14" Padding="14,12" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Current status" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DiagnosticsText}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Width="390" Background="{StaticResource PanelGlassBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="20" Padding="18" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="AI Providers" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Enable AI only when you want semantic analysis running in the background." FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="This area controls the real AI runtime gate, local endpoints, and cloud credentials." Style="{StaticResource SectionCaptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />

                                <CheckBox Content="Enable AI globally" Style="{StaticResource FilterCheckBoxStyle}" IsChecked="{Binding EnableAiGlobally}" Margin="0,18,0,0" />

                                <TextBlock Text="Active vision provider" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <ComboBox SelectedValue="{Binding AiVisionProviderId}" SelectedValuePath="Tag" Margin="0,8,0,0">
                                    <ComboBoxItem Content="LM Studio" Tag="lmstudio" />
                                </ComboBox>

                                <TextBlock Text="Active LM Studio vision model" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <ComboBox ItemsSource="{Binding LmStudioAvailableModels}" SelectedItem="{Binding LmStudioVisionModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEditable="False" Margin="0,8,0,0" />

                                <TextBlock Text="LM Studio endpoint" FontWeight="SemiBold" Margin="0,18,0,0" />
                                <TextBox Text="{Binding LmStudioEndpoint}" Margin="0,8,0,0" />

                                <Border Background="{StaticResource PanelAltBrush}" CornerRadius="14" Padding="14,12" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Future providers" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <TextBlock Text="Ollama and OpenAI vision execution are not enabled in this build yet. LM Studio is the only active visual-tagging provider exposed for QA and product testing." Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource PanelAltBrush}" CornerRadius="14" Padding="14,12" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Provider readiness" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="10,6" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding ConnectionTestStatusText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                                        </Border>
                                        <TextBlock Text="{Binding ActiveAiModelSummary}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding AiIndexingProgressText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding AiIndexingDetailText}" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding AiProviderStatusText}" Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <ProgressBar Margin="0,12,0,0" Height="7" Minimum="0" Maximum="100" Value="{Binding AiIndexingProgressPercent}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                <Button Click="RefreshProviders_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                        <TextBlock Text="Test Connections" />
                    </StackPanel>
                </Button>
                <Button Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                        <TextBlock Text="Save Settings" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Grid>
    </Border>
</Window>
