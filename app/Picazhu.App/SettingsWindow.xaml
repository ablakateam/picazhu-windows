<Window x:Class="Picazhu.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PICAZHU Settings"
        Width="980"
        Height="760"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource TextBrush}">
    <Window.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelGlassBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsHelpStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SectionCaptionStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="18" />
        </Style>

        <Style x:Key="SettingsValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="18" />
        </Style>

        <Style x:Key="SettingsToggleStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="5"
                                    Background="{StaticResource ControlBrush}"
                                    BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="Check"
                                           Text="&#xE73E;"
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="10"
                                           Foreground="#10161F"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Settings" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="General behavior, cache control, and AI provider configuration."
                               Style="{StaticResource SettingsHelpStyle}"
                               Margin="0,6,0,0" />
                    <Border Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="12"
                            Padding="12,7"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            MaxWidth="620">
                        <TextBlock Text="{Binding SettingsStatusText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <Button Grid.Column="1"
                        Click="Close_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        MinWidth="112"
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE711;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="Close" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Margin="0,22,0,18">
                <StackPanel>
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Workspace" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Browsing behavior" FontSize="19" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="Control the default browsing experience, theme, and thumbnail cache budget."
                                           Style="{StaticResource SettingsHelpStyle}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" MinWidth="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme" Style="{StaticResource SettingsLabelStyle}" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          SelectedValue="{Binding ThemeMode}"
                                          SelectedValuePath="Tag"
                                          MinHeight="42">
                                    <ComboBoxItem Content="Dark" Tag="Dark" />
                                    <ComboBoxItem Content="Light" Tag="Light" />
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Default subfolder scan" Style="{StaticResource SettingsLabelStyle}" />
                                <CheckBox Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Include subfolders when adding new folders."
                                          Style="{StaticResource SettingsToggleStyle}"
                                          IsChecked="{Binding IncludeSubfolders}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Thumbnail cache limit" Style="{StaticResource SettingsLabelStyle}" />
                                <Grid Grid.Row="4" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ThumbnailCacheLimitMb}"
                                             MinHeight="42"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="MB"
                                               Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>

                                <Border Grid.Row="6"
                                        Grid.ColumnSpan="2"
                                        Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="16"
                                        Padding="16,14">
                                    <StackPanel>
                                        <TextBlock Text="Current status" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DiagnosticsText}" Margin="0,8,0,0" Style="{StaticResource SettingsValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="AI Providers" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Semantic analysis controls" FontSize="19" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Text="Enable AI only when you want background OCR and visual tagging. LM Studio is the active visual provider in this build."
                                           Style="{StaticResource SettingsHelpStyle}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" MinWidth="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AI runtime" Style="{StaticResource SettingsLabelStyle}" />
                                <CheckBox Grid.Row="0"
                                          Grid.Column="1"
                                          Content="Enable AI globally."
                                          Style="{StaticResource SettingsToggleStyle}"
                                          IsChecked="{Binding EnableAiGlobally}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Vision provider" Style="{StaticResource SettingsLabelStyle}" />
                                <ComboBox Grid.Row="2"
                                          Grid.Column="1"
                                          SelectedValue="{Binding AiVisionProviderId}"
                                          SelectedValuePath="Tag"
                                          MinHeight="42">
                                    <ComboBoxItem Content="LM Studio" Tag="lmstudio" />
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="LM Studio model" Style="{StaticResource SettingsLabelStyle}" />
                                <StackPanel Grid.Row="4" Grid.Column="1">
                                    <ComboBox ItemsSource="{Binding LmStudioAvailableModels}"
                                              SelectedItem="{Binding LmStudioVisionModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ToolTip="{Binding LmStudioVisionModel}"
                                              IsEditable="False"
                                              MinHeight="42" />
                                    <TextBlock Text="{Binding ActiveAiModelSummary}"
                                               Style="{StaticResource SettingsValueStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="LM Studio endpoint" Style="{StaticResource SettingsLabelStyle}" />
                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         Text="{Binding LmStudioEndpoint}"
                                         ToolTip="{Binding LmStudioEndpoint}"
                                         MinHeight="42"
                                         VerticalContentAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="16"
                                        Padding="16,14">
                                    <StackPanel>
                                        <TextBlock Text="Provider readiness" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="12,8" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding ConnectionTestStatusText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18" />
                                        </Border>
                                        <TextBlock Text="{Binding AiProviderStatusText}" Margin="0,10,0,0" Style="{StaticResource SettingsValueStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="{StaticResource PanelAltBrush}"
                                        CornerRadius="16"
                                        Padding="16,14">
                                    <StackPanel>
                                        <TextBlock Text="AI indexing" Style="{StaticResource SidebarSectionTitleStyle}" />
                                        <TextBlock Text="{Binding AiIndexingProgressText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding AiIndexingDetailText}" Margin="0,6,0,0" Style="{StaticResource SettingsValueStyle}" />
                                        <ProgressBar Margin="0,12,0,0"
                                                     Height="8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding AiIndexingProgressPercent}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource PanelGlassBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18"
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Future providers" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="Ollama and OpenAI vision execution are intentionally labeled as future providers in this build. LM Studio is the only active visual-tagging provider exposed for QA and product testing."
                                       Style="{StaticResource SettingsHelpStyle}"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Close discards unsaved edits. Save applies settings immediately."
                           Style="{StaticResource SettingsHelpStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Click="RefreshProviders_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            MinWidth="182"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="Test Connections" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Button>

                    <Button Click="Save_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="164">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE74E;" Style="{StaticResource IconTextBlockStyle}" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="Save Settings" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
