<Window x:Class="Picazhu.App.PhoneImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Picazhu.App"
        Title="Import from iPhone"
        Width="1080"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter" />
        <Style x:Key="PhoneImportTileItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource HeroPanelBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="22" Padding="20" Effect="{DynamicResource PanelShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Import from iPhone" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Browse trusted USB devices, copy original camera media, and add the import to PICAZHU automatically." Style="{StaticResource SectionCaptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="14,10" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EA;" Style="{StaticResource IconTextBlockStyle}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="Camera originals only" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,16,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource PanelGlassBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Device" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="Unlock the iPhone and approve Trust This Computer before scanning." Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,14" TextWrapping="Wrap" />
                            <Button Click="RefreshDevices_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,12" IsEnabled="{Binding CanRefresh}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource ButtonIconTextBlockStyle}" Margin="0,0,8,0" />
                                    <TextBlock Text="Refresh Devices" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <ListBox x:Name="DeviceList"
                                     ItemsSource="{Binding Devices}"
                                     SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                     SelectionChanged="DeviceList_SelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ManufacturerText}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding TrustHint}" Foreground="{DynamicResource AccentBrush}" FontSize="11" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="16" Padding="18" Visibility="{Binding HasDevices, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8EA;" Style="{StaticResource IconTextBlockStyle}" FontSize="30" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="No devices yet" FontWeight="SemiBold" FontSize="17" HorizontalAlignment="Center" Margin="0,12,0,4" />
                                    <TextBlock Text="Connect the iPhone by USB, unlock it, then refresh." Foreground="{DynamicResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2" Margin="0,16,0,0">
                            <Button Click="ScanDevice_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,0,16" IsEnabled="{Binding CanScanDevice}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource ButtonIconTextBlockStyle}" Margin="0,0,8,0" />
                                    <TextBlock Text="Scan Camera Media" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="Destination" Style="{StaticResource SidebarSectionTitleStyle}" Foreground="{DynamicResource AccentBrush}" />
                            <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,8" />
                            <Button Click="BrowseDestination_Click" Style="{StaticResource GhostButtonStyle}" Margin="0" Padding="12,9" MinHeight="40">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE838;" Style="{StaticResource ButtonIconTextBlockStyle}" Margin="0,0,8,0" />
                                    <TextBlock Text="Choose Folder" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource PanelGlassBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="22" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Media to import" Style="{StaticResource SectionTitleStyle}" FontSize="22" />
                                <TextBlock Text="{Binding MediaSummaryText}" Style="{StaticResource SectionCaptionStyle}" Margin="0,5,0,0" />
                                <StackPanel Margin="0,8,0,0" Visibility="{Binding HasThumbnailProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ThumbnailProgressText}" Foreground="{DynamicResource MutedBrush}" FontSize="11" />
                                    <ProgressBar Minimum="0" Maximum="100" Height="4" Value="{Binding ThumbnailProgressPercent}" Margin="0,6,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Button Click="SelectAll_Click" Style="{StaticResource GhostButtonStyle}" Padding="12,8" MinHeight="38" Margin="0,0,8,0" Content="Select All" IsEnabled="{Binding HasMediaItems}" />
                                <Button Click="SelectNone_Click" Style="{StaticResource GhostButtonStyle}" Padding="12,8" MinHeight="38" Margin="0" Content="Select None" IsEnabled="{Binding HasMediaItems}" />
                            </WrapPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <ListBox ItemsSource="{Binding MediaItems}"
                                     SelectionMode="Multiple"
                                     ItemContainerStyle="{StaticResource PhoneImportTileItemStyle}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     Visibility="{Binding HasMediaItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <local:VirtualizingWrapPanel ItemWidth="196" ItemHeight="270" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="Card"
                                                Width="184"
                                                Height="258"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="10"
                                                Margin="0,0,12,12"
                                                Effect="{DynamicResource CardShadow}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="150" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border Background="{DynamicResource ControlStrongBrush}" CornerRadius="15" ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image.Style>
                                                                <Style TargetType="{x:Type Image}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasThumbnail}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="{x:Type StackPanel}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasThumbnail}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{Binding IconGlyph}" Style="{StaticResource IconTextBlockStyle}" FontSize="30" HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" />
                                                            <TextBlock Text="Loading preview" Foreground="{DynamicResource MutedBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                                        </StackPanel>
                                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="{DynamicResource MediaOverlayBrush}" CornerRadius="10" Padding="8,5" Margin="8">
                                                            <TextBlock Text="{Binding KindLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MediaOverlayTextBrush}" />
                                                        </Border>
                                                        <CheckBox HorizontalAlignment="Right" VerticalAlignment="Top" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="8" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Row="1" Margin="2,10,2,0">
                                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding RelativePath}" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                                                    <Grid Margin="0,9,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="11" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ModifiedText}" Foreground="{DynamicResource MutedBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                                                    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="18" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center" Width="430" Visibility="{Binding HasMediaItems, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                <StackPanel>
                                    <TextBlock Text="&#xF57C;" Style="{StaticResource IconTextBlockStyle}" FontSize="34" HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="Scan a device to load media" FontWeight="SemiBold" FontSize="19" HorizontalAlignment="Center" Margin="0,12,0,4" />
                                    <TextBlock Text="PICAZHU will show supported camera photos and videos here before copying originals." TextAlignment="Center" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource HeroPanelBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DetailText}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                        <ProgressBar Minimum="0" Maximum="100" Height="6" Value="{Binding ProgressPercent}" Margin="0,10,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Button Click="CancelImport_Click" Style="{StaticResource GhostButtonStyle}" MinWidth="92" Margin="0,0,8,0" Content="Cancel" IsEnabled="{Binding CanCancel}" />
                        <Button Click="Import_Click" Style="{StaticResource PrimaryButtonStyle}" MinWidth="154" Margin="0,0,8,0" Content="{Binding ImportButtonText}" IsEnabled="{Binding CanImport}" />
                        <Button Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" MinWidth="92" Margin="0" Content="Close" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
